# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# Path to your downloaded Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# Sheet tab name (default: Sheet1)
SHEET_NAME=Contacts

# ── App config ─────────────────────────────────────────────────────────────────
# Only extract from these JIDs (comma-separated). Leave empty = all chats.
# Example: 919876543210@s.whatsapp.net,911234567890@s.whatsapp.net
ALLOWED_JIDS=

# Minimum confidence to write a row (0–1). 0.6 recommended.
MIN_CONFIDENCE=0.6

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
